# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Super Admin (Owner) Telegram numeric user ID
SUPER_ADMIN_ID=123456789

# AI Provider: openai or gemini
AI_PROVIDER=openai
AI_API_KEY=your_api_key_here
AI_MODEL=gpt-4o-mini

# Database: sqlite (default) or postgres
DB_BACKEND=sqlite
DATABASE_URL=sqlite:///./data/gdoc.db
POSTGRES_DSN=postgresql://gdoc:gdoc@localhost:5432/gdoc

# Redis cache
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=gdoc:
CACHE_TTL_SECONDS=300

# Deployment mode: polling (default) or webhook
USE_WEBHOOK=false
WEBHOOK_URL=https://your-domain.com
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=

# Concurrency limits
AI_CONCURRENCY=10
DB_WRITE_CONCURRENCY=5

# Notification queue (cross-group / admin alerts)
NOTIFY_QUEUE_DELAY_SECONDS=0.15
NOTIFY_DEDUPE_TTL_SECONDS=3600
NOTIFY_CROSS_GROUP_MAX_TARGETS=50

LOG_LEVEL=INFO
DATA_DIR=./data
